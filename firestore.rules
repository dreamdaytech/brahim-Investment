rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // inquiries
    match /inquiries/{inquiryId} {
      allow read, write: if true; // It's a prototype
    }

    // clients
    match /clients/{clientId} {
      allow read, write: if true; // It's a prototype
    }
  }
}
